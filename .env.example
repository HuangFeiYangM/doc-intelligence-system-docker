# ============================================
# Document Intelligence System - Environment Variables
# ============================================
#
# Copy this file to .env and fill in your actual values.
# Never commit .env to version control!
#
# Variables marked with [REQUIRED] must be filled.
# ============================================

# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
# APPLICATION CONFIGURATION
# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

# Application name and version
APP_NAME="Doc Intelligence System"
APP_VERSION="1.0.0"

# Debug mode (enable for development, disable for production)
DEBUG=false

# Server host and port
HOST="0.0.0.0"
PORT=8001

# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
# DATABASE CONFIGURATION (MySQL)
# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

# Database connection URL
# Format: mysql+asyncmy://user:password@host:port/database_name
DATABASE_URL="mysql+asyncmy://user:password@localhost:3306/doc_intel"

# Database connection pool settings
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
# REDIS CONFIGURATION
# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

# Redis connection URL
REDIS_URL="redis://localhost:6379/0"

# Redis password (if required)
REDIS_PASSWORD=

# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
# CELERY CONFIGURATION (Optional)
# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

# Celery broker URL (Redis is recommended)
CELERY_BROKER_URL="redis://localhost:6379/1"

# Celery result backend
CELERY_RESULT_BACKEND="redis://localhost:6379/2"

# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
# DEEPSEEK LLM API CONFIGURATION [REQUIRED]
# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

# DeepSeek API Key - REQUIRED for LLM features
# Get your API key from https://platform.deepseek.com/
DEEPSEEK_API_KEY=""

# DeepSeek API base URL (usually don't change this)
DEEPSEEK_API_BASE="https://api.deepseek.com"

# Model name (check DeepSeek documentation for available models)
DEEPSEEK_MODEL="deepseek-chat"

# Maximum tokens in response
DEEPSEEK_MAX_TOKENS=4096

# Temperature (0.0-2.0, higher = more creative)
DEEPSEEK_TEMPERATURE=0.7

# API timeout in seconds
DEEPSEEK_TIMEOUT=90

# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
# FILE UPLOAD CONFIGURATION
# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

# Maximum upload size in bytes (default: 50MB)
MAX_UPLOAD_SIZE=52428800

# Allowed file extensions (JSON array or comma-separated)
ALLOWED_EXTENSIONS='[".pdf", ".docx", ".doc", ".xlsx", ".xls"]'

# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
# FILE PATH CONFIGURATION
# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

# Base directory for file storage (relative to project root)
# These paths are relative to the backend directory
UPLOAD_DIR="./backend/uploads"
TEMPLATE_DIR="./backend/templates"
OUTPUT_DIR="./backend/outputs"
LOG_DIR="./backend/logs"

# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
# TASK PROCESSING CONFIGURATION
# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

# Maximum number of concurrent tasks
MAX_CONCURRENT_TASKS=5

# Task timeout in seconds
TASK_TIMEOUT=300

# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
# MYSQL CONTAINER CONFIGURATION (Docker Compose)
# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

# MySQL root password
MYSQL_ROOT_PASSWORD=password

# MySQL database name
MYSQL_DATABASE=doc_intel

# MySQL user name
MYSQL_USER=user

# MySQL user password
MYSQL_PASSWORD=password

# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
# OPTIONAL ADVANCED CONFIGURATION
# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

# Application environment (development, production, test)
APP_ENV="development"

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL="INFO"

# CORS allowed origins (comma-separated)
CORS_ALLOWED_ORIGINS="*"

# API rate limiting
RATE_LIMIT_PER_MINUTE=60

# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
# TESTING CONFIGURATION
# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

# Test database URL (used when running tests)
TEST_DATABASE_URL="mysql+asyncmy://root:password@localhost:3306/doc_intel_test"

# Test API key (for testing without real API calls)
TEST_DEEPSEEK_API_KEY="sk-test-key-for-testing-only"

# Test file paths
TEST_UPLOAD_DIR="./backend/tests/test_uploads"
TEST_OUTPUT_DIR="./backend/tests/test_outputs"

# Test-specific upload size limit (10MB)
TEST_MAX_UPLOAD_SIZE=10485760

# Test allowed extensions
TEST_ALLOWED_EXTENSIONS='[".pdf", ".docx", ".xlsx"]'

# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
# NOTES
# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

# 1. For Docker Compose deployment, update these values:
#    - DATABASE_URL: use "mysql+asyncmy://user:password@mysql:3306/doc_intel"
#    - REDIS_URL: use "redis://redis:6379/0"
#    - CELERY_BROKER_URL: use "redis://redis:6379/1"
#    - CELERY_RESULT_BACKEND: use "redis://redis:6379/2"
#
# 2. Production recommendations:
#    - Set DEBUG=false
#    - Use strong passwords for MySQL and Redis
#    - Configure proper CORS_ALLOWED_ORIGINS
#    - Set appropriate file size limits
#
# 3. Security warning:
#    - NEVER commit .env files to version control
#    - Use environment-specific .env files (.env.production, .env.staging)
#    - Consider using secrets management in production